#!/bin/bash
set -euo pipefail

log() {
    echo "[oyo-portable-mode] $*"
}

is_portable_mode() {
    grep -qw 'oyo.mode=portable' /proc/cmdline
}

hide_calamares_menu() {
    mkdir -p /usr/local/share/applications

    cat >/usr/local/share/applications/calamares.desktop <<'EOF'
[Desktop Entry]
Type=Application
Version=1.0
Name=Install System
GenericName=System Installer
Keywords=calamares;system;installer;
TryExec=/bin/false
Exec=/bin/false
Comment=Calamares — System Installer
Icon=calamares
Terminal=false
StartupNotify=false
Categories=Qt;System;
NoDisplay=true
Hidden=true
X-AppStream-Ignore=true
EOF

    log "Calamares メニューを非表示にしました"
}

remove_calamares_desktop_icons() {
    for d in /etc/skel/Desktop /home/*/Desktop; do
        [ -d "$d" ] || continue
        rm -f \
            "$d/calamares.desktop" \
            "$d/install-system.desktop" \
            "$d/Install System.desktop" \
            "$d/インストール.desktop" \
            2>/dev/null || true
    done

    log "Desktop の Calamares アイコンを削除しました"
}

apply_journald_volatile() {
    # persistent journal を削除
    rm -rf /var/log/journal 2>/dev/null || true

    mkdir -p /etc/systemd/journald.conf.d
    cat >/etc/systemd/journald.conf.d/90-oyo-portable.conf <<'EOF'
[Journal]
Storage=volatile
RuntimeMaxUse=64M
SystemMaxUse=64M
EOF

    systemctl restart systemd-journald || true
    log "journald を volatile 化しました"
}

mount_tmpfs_if_needed() {
    mkdir -p /tmp /var/tmp

    if ! mountpoint -q /tmp; then
        mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /tmp || true
        log "/tmp を tmpfs 化しました"
    fi

    if ! mountpoint -q /var/tmp; then
        mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /var/tmp || true
        log "/var/tmp を tmpfs 化しました"
    fi
}

mount_cache_tmpfs() {

    mkdir -p /var/cache

    if ! mountpoint -q /var/cache; then
        mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /var/cache || true
        log "/var/cache を tmpfs 化しました"
    fi
}

mount_log_tmpfs() {

    mkdir -p /var/log

    if ! mountpoint -q /var/log; then
        mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /var/log || true
        log "/var/log を tmpfs 化しました"
    fi

    # systemd が必要とするディレクトリを作成
    mkdir -p /var/log/journal
    mkdir -p /var/log/apt
    mkdir -p /var/log/private
}

disable_background_writers() {
    local units=(
        apt-daily.timer
        apt-daily.service
        apt-daily-upgrade.timer
        apt-daily-upgrade.service
        man-db.timer
        fstrim.timer
        packagekit.service
        packagekit-offline-update.service
    )

    for u in "${units[@]}"; do
        systemctl stop "$u" 2>/dev/null || true
        systemctl mask "$u" 2>/dev/null || true
    done

    log "バックグラウンド更新系ユニットを停止・mask しました"
}

apply_file_customizations() {
    hide_calamares_menu
    remove_calamares_desktop_icons
}

update_favorite_apps() {
    command -v gsettings >/dev/null 2>&1 || return 0

    if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
        log "DBUS_SESSION_BUS_ADDRESS が無いため favorite-apps 更新をスキップ"
        return 0
    fi

    if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        log "XDG_RUNTIME_DIR が無いため favorite-apps 更新をスキップ"
        return 0
    fi

    gsettings set org.gnome.shell favorite-apps \
"['firefox-esr.desktop','org.gnome.Nautilus.desktop','org.gnome.Software.desktop','org.gnome.Settings.desktop','org.gnome.Terminal.desktop']" \
        || true

    log "favorite-apps を portable 用に更新しました"
}

reduce_tracker_activity() {
    command -v gsettings >/dev/null 2>&1 || return 0

    if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] || [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        log "DBus 未接続のため Tracker 設定をスキップ"
        return 0
    fi

    gsettings set org.freedesktop.Tracker3.Miner.Files enable-monitors false || true
    gsettings set org.freedesktop.Tracker3.Miner.Files crawling-interval -2 || true

    log "Tracker の監視・巡回を抑制しました"
}

run_boot() {
    if ! is_portable_mode; then
        exit 0
    fi

    log "portable モード検出 (--boot)"

    apply_file_customizations
    mount_log_tmpfs
    apply_journald_volatile
    mount_tmpfs_if_needed
    mount_cache_tmpfs
    disable_background_writers
}

run_autostart() {
    if is_portable_mode; then
        log "portable モードのため Calamares 自動起動を抑止します"
        apply_file_customizations
        exit 0
    fi

    log "Calamares を通常起動します"

    exec sudo -E env \
        QT_QPA_PLATFORM=xcb \
        QT_AUTO_SCREEN_SCALE_FACTOR=0 \
        QT_SCALE_FACTOR=1 \
        calamares
}

run_session() {
    echo "$(date) USER=${USER:-} HOME=${HOME:-} DBUS=${DBUS_SESSION_BUS_ADDRESS:-}" >> /tmp/oyo-portable-session.log

    if ! is_portable_mode; then
        exit 0
    fi

    log "portable モード検出 (--session)"

    update_favorite_apps
    reduce_tracker_activity
}

case "${1:-}" in
    --boot)
        run_boot
        ;;
    --autostart)
        run_autostart
        ;;
    --session)
        run_session
        ;;
    *)
        echo "使い方: $0 --boot | --autostart | --session" >&2
        exit 1
        ;;
esac

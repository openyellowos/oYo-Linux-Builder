#!/bin/bash
set -euo pipefail

log() {
    echo "[oyo-portable-mode] $*"
}

is_portable_mode() {
    grep -qw 'oyo.mode=portable' /proc/cmdline
}

ensure_dir() {
    local path="$1"
    local mode="$2"

    mkdir -p "$path"
    chmod "$mode" "$path" 2>/dev/null || true
}

ensure_owner_if_user_exists() {
    local path="$1"
    local user="$2"
    local group="$3"

    if id "$user" >/dev/null 2>&1; then
        chown "$user:$group" "$path" 2>/dev/null || true
    fi
}

hide_calamares_menu() {
    mkdir -p /usr/local/share/applications

    cat >/usr/local/share/applications/calamares.desktop <<'EOF'
[Desktop Entry]
Type=Application
Version=1.0
Name=Install System
GenericName=System Installer
Keywords=calamares;system;installer;
TryExec=/bin/false
Exec=/bin/false
Comment=Calamares — System Installer
Icon=calamares
Terminal=false
StartupNotify=false
Categories=Qt;System;
NoDisplay=true
Hidden=true
X-AppStream-Ignore=true
EOF

    log "Calamares メニューを非表示にしました"
}

remove_calamares_desktop_icons() {
    for d in /etc/skel/Desktop /home/*/Desktop; do
        [ -d "$d" ] || continue
        rm -f \
            "$d/calamares.desktop" \
            "$d/install-system.desktop" \
            "$d/Install System.desktop" \
            "$d/インストール.desktop" \
            2>/dev/null || true
    done

    log "Desktop の Calamares アイコンを削除しました"
}

apply_journald_volatile() {
    rm -rf /var/log/journal 2>/dev/null || true

    mkdir -p /etc/systemd/journald.conf.d
    cat >/etc/systemd/journald.conf.d/90-oyo-portable.conf <<'EOF'
[Journal]
Storage=volatile
RuntimeMaxUse=64M
SystemMaxUse=64M
EOF

    systemctl restart systemd-journald || true
    log "journald を volatile 化しました"
}

mount_tmpfs_if_needed() {
    mkdir -p /tmp /var/tmp

    if ! mountpoint -q /tmp; then
        mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /tmp || true
        log "/tmp を tmpfs 化しました"
    fi

    if ! mountpoint -q /var/tmp; then
        mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /var/tmp || true
        log "/var/tmp を tmpfs 化しました"
    fi
}

mount_log_tmpfs() {
    mkdir -p /var/log

    if ! mountpoint -q /var/log; then
        mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /var/log || true
        log "/var/log を tmpfs 化しました"
    fi

    ensure_dir /var/log/journal 0755
    ensure_dir /var/log/apt 0755
    ensure_dir /var/log/private 0700
    ensure_dir /var/log/PackageKit 0755
}

ensure_package_management_layout() {
    #
    # GNOME Software / PackageKit / APT が期待する基本ディレクトリを確認
    # ここでは /var/cache 自体は tmpfs 化しない
    #

    # APT
    ensure_dir /var/cache/apt 0755
    ensure_dir /var/cache/apt/archives 0755
    ensure_dir /var/cache/apt/archives/partial 0700
    ensure_owner_if_user_exists /var/cache/apt/archives/partial _apt root

    ensure_dir /var/lib/apt 0755
    ensure_dir /var/lib/apt/lists 0755
    ensure_dir /var/lib/apt/lists/partial 0700
    ensure_owner_if_user_exists /var/lib/apt/lists/partial _apt root

    # PackageKit
    ensure_dir /var/cache/PackageKit 0755
    ensure_dir /var/cache/PackageKit/downloads 0755
    ensure_dir /var/cache/PackageKit/metadata 0755
    ensure_dir /var/lib/PackageKit 0755

    # AppStream / app-info / GNOME Software
    ensure_dir /var/cache/app-info 0755
    ensure_dir /var/cache/app-info/xmls 0755
    ensure_dir /var/cache/app-info/icons 0755

    ensure_dir /var/lib/app-info 0755
    ensure_dir /var/lib/app-info/yaml 0755
    ensure_dir /var/lib/app-info/icons 0755

    # software catalog 系
    ensure_dir /var/cache/swcatalog 0755
    ensure_dir /var/cache/swcatalog/cache 0755
    ensure_dir /var/cache/swcatalog/icons 0755
    ensure_dir /var/cache/swcatalog/yaml 0755
    ensure_dir /var/lib/swcatalog 0755
    ensure_dir /var/lib/swcatalog/yaml 0755
    ensure_dir /var/lib/swcatalog/icons 0755

    # 補助的なキャッシュ
    ensure_dir /var/cache/fontconfig 0755
    ensure_dir /var/cache/man 0755
    ensure_dir /var/cache/debconf 0700
    ensure_dir /var/cache/ldconfig 0755
    ensure_dir /var/cache/private 0700

    log "APT / PackageKit / GNOME Software 用ディレクトリを確認しました"
}

configure_packagekit_for_portable() {
    mkdir -p /etc/PackageKit

    cat >/etc/PackageKit/PackageKit.conf <<'EOF'
[Daemon]
UseSyslog=true
KeepCache=false
ShutdownTimeout=300

[OfflineUpdate]
AllowOfflineUpdate=false
EOF

    systemctl unmask packagekit.service 2>/dev/null || true
    systemctl unmask packagekit.socket 2>/dev/null || true

    log "PackageKit を portable 向け設定にしました"
}

configure_apt_for_portable() {
    mkdir -p /etc/apt/apt.conf.d

    cat >/etc/apt/apt.conf.d/90oyo-portable <<'EOF'
APT::Keep-Downloaded-Packages "false";
Acquire::Retries "3";
EOF

    log "APT を portable 向け設定にしました"
}

disable_background_writers() {
    local units=(
        apt-daily.timer
        apt-daily.service
        apt-daily-upgrade.timer
        apt-daily-upgrade.service
        man-db.timer
        fstrim.timer
    )

    for u in "${units[@]}"; do
        systemctl stop "$u" 2>/dev/null || true
        systemctl mask "$u" 2>/dev/null || true
    done

    # PackageKit 本体は GNOME Software のために残す
    systemctl stop packagekit-offline-update.service 2>/dev/null || true
    systemctl mask packagekit-offline-update.service 2>/dev/null || true

    systemctl unmask packagekit.service 2>/dev/null || true
    systemctl unmask packagekit.socket 2>/dev/null || true

    log "バックグラウンド更新系ユニットを停止・mask しました（PackageKit本体は維持）"
}

apply_file_customizations() {
    hide_calamares_menu
    remove_calamares_desktop_icons
}

update_favorite_apps() {
    command -v gsettings >/dev/null 2>&1 || return 0

    if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
        log "DBUS_SESSION_BUS_ADDRESS が無いため favorite-apps 更新をスキップ"
        return 0
    fi

    if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        log "XDG_RUNTIME_DIR が無いため favorite-apps 更新をスキップ"
        return 0
    fi

    gsettings set org.gnome.shell favorite-apps \
"['firefox-esr.desktop','org.gnome.Nautilus.desktop','org.gnome.Software.desktop','org.gnome.Settings.desktop','org.gnome.Terminal.desktop']" \
        || true

    log "favorite-apps を portable 用に更新しました"
}

reduce_tracker_activity() {
    command -v gsettings >/dev/null 2>&1 || return 0

    if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] || [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        log "DBus 未接続のため Tracker 設定をスキップ"
        return 0
    fi

    gsettings set org.freedesktop.Tracker3.Miner.Files enable-monitors false || true
    gsettings set org.freedesktop.Tracker3.Miner.Files crawling-interval -2 || true

    log "Tracker の監視・巡回を抑制しました"
}

redirect_home_cache_to_ram() {
    if [ -z "${HOME:-}" ]; then
        log "HOME が無いため ~/.cache の RAM 化をスキップ"
        return 0
    fi

    if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        log "XDG_RUNTIME_DIR が無いため ~/.cache の RAM 化をスキップ"
        return 0
    fi

    local ram_cache="$XDG_RUNTIME_DIR/oyo-cache"
    local home_cache="$HOME/.cache"

    mkdir -p "$ram_cache"
    chmod 700 "$ram_cache" 2>/dev/null || true
    mkdir -p "$HOME"

    if [ -L "$home_cache" ]; then
        local current target
        current="$(readlink -f "$home_cache" 2>/dev/null || true)"
        target="$(readlink -f "$ram_cache" 2>/dev/null || true)"
        if [ -n "$current" ] && [ -n "$target" ] && [ "$current" = "$target" ]; then
            log "~/.cache はすでに RAM 化済みです"
            return 0
        fi
        rm -f "$home_cache"
    elif [ -d "$home_cache" ]; then
        rm -rf "$home_cache"
    elif [ -e "$home_cache" ]; then
        rm -f "$home_cache"
    fi

    ln -sfn "$ram_cache" "$home_cache"
    log "~/.cache -> $ram_cache に切り替えました"
}

redirect_path_to_runtime_dir() {
    local src="$1"
    local dst="$2"

    mkdir -p "$(dirname "$src")"
    mkdir -p "$dst"
    chmod 700 "$dst" 2>/dev/null || true

    if [ -L "$src" ]; then
        local current target
        current="$(readlink -f "$src" 2>/dev/null || true)"
        target="$(readlink -f "$dst" 2>/dev/null || true)"
        if [ -n "$current" ] && [ -n "$target" ] && [ "$current" = "$target" ]; then
            log "$src はすでに RAM 化済みです"
            return 0
        fi
        rm -f "$src"
    elif [ -d "$src" ]; then
        rm -rf "$src"
    elif [ -e "$src" ]; then
        rm -f "$src"
    fi

    ln -sfn "$dst" "$src"
    log "$src -> $dst に切り替えました"
}

redirect_chrome_runtime_paths_to_ram() {
    if [ -z "${HOME:-}" ]; then
        log "HOME が無いため Chrome 用 RAM 化をスキップ"
        return 0
    fi

    if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        log "XDG_RUNTIME_DIR が無いため Chrome 用 RAM 化をスキップ"
        return 0
    fi

    local chrome_config_dir="$HOME/.config/google-chrome"
    local chrome_runtime_base="$XDG_RUNTIME_DIR/oyo-google-chrome"

    if [ ! -d "$chrome_config_dir" ] && [ ! -L "$chrome_config_dir" ]; then
        mkdir -p "$chrome_config_dir"
    fi

    mkdir -p "$chrome_runtime_base"
    chmod 700 "$chrome_runtime_base" 2>/dev/null || true

    redirect_path_to_runtime_dir \
        "$chrome_config_dir/Service Worker" \
        "$chrome_runtime_base/Service Worker"

    redirect_path_to_runtime_dir \
        "$chrome_config_dir/Code Cache" \
        "$chrome_runtime_base/Code Cache"

    redirect_path_to_runtime_dir \
        "$chrome_config_dir/GPUCache" \
        "$chrome_runtime_base/GPUCache"

    log "Chrome の Service Worker / Code Cache / GPUCache を RAM 化しました"
}

refresh_packagekit_if_available() {
    systemctl unmask packagekit.service 2>/dev/null || true
    systemctl unmask packagekit.socket 2>/dev/null || true

    if systemctl list-unit-files | grep -q '^packagekit\.service'; then
        systemctl restart packagekit.service 2>/dev/null || true
        log "packagekit.service を再起動しました"
    fi
}

run_boot() {
    if ! is_portable_mode; then
        exit 0
    fi

    log "portable モード検出 (--boot)"

    apply_file_customizations
    mount_log_tmpfs
    apply_journald_volatile
    mount_tmpfs_if_needed

    # GNOME Software 優先版:
    # /var/cache 全体は tmpfs 化しない
    ensure_package_management_layout
    configure_packagekit_for_portable
    configure_apt_for_portable
    disable_background_writers
    refresh_packagekit_if_available
}

run_autostart() {
    if is_portable_mode; then
        log "portable モードのため Calamares 自動起動を抑止します"
        apply_file_customizations
        exit 0
    fi

    log "Calamares を通常起動します"

    exec sudo -E env \
        QT_QPA_PLATFORM=xcb \
        QT_AUTO_SCREEN_SCALE_FACTOR=0 \
        QT_SCALE_FACTOR=1 \
        calamares
}

run_session() {
    echo "$(date) USER=${USER:-} HOME=${HOME:-} DBUS=${DBUS_SESSION_BUS_ADDRESS:-}" >> /tmp/oyo-portable-session.log

    if ! is_portable_mode; then
        exit 0
    fi

    log "portable モード検出 (--session)"

    redirect_home_cache_to_ram
    redirect_chrome_runtime_paths_to_ram
    update_favorite_apps
    reduce_tracker_activity
}

case "${1:-}" in
    --boot)
        run_boot
        ;;
    --autostart)
        run_autostart
        ;;
    --session)
        run_session
        ;;
    *)
        echo "使い方: $0 --boot | --autostart | --session" >&2
        exit 1
        ;;
esac
